#vagrant folder
/.vagrant

# === Тимчасові папки Yii2 (Обов'язково для Docker) ===
# Ігноруємо весь кеш, сесії та логи, які пише Yii2
/runtime/*
!/runtime/.gitignore

# Ігноруємо публічні асети (скрипти і стилі), які Yii автоматично копіює в web
/web/assets/*
!/web/assets/.gitignore

# === Налаштування Docker та оточення ===
# Локальні змінні оточення (паролі до бази даних тощо)
.env.local
.env.local.php
.env.*.local

# Якщо Docker створює якісь локальні лог-файли в корені
*.log